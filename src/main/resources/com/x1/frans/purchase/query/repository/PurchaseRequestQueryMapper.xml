<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.x1.frans.purchase.query.repository.PurchaseRequestQueryMapper">

    <resultMap id="purchaseRequestSimpleResultMap" type="com.x1.frans.purchase.query.dto.PurchaseRequestSimpleDto">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="title" column="title"/>
        <result property="status" column="status"/>
        <result property="requestedDeliveryDate" column="requested_delivery_date"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="purchaseRequestProductResultMap" type="com.x1.frans.purchase.query.dto.PurchaseRequestProductSimpleDto">
        <id property="id" column="product_id"/>
        <result property="no" column="no"/>
        <result property="quantity" column="quantity"/>
        <result property="remarks" column="remarks"/>
        <result property="productId" column="product_id"/>
    </resultMap>

    <resultMap id="purchaseRequestDetailResultMap" type="com.x1.frans.purchase.query.dto.PurchaseRequestDetailDto">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="title" column="title"/>
        <result property="status" column="status"/>
        <result property="requestedDeliveryDate" column="requested_delivery_date"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <collection property="products" ofType="com.x1.frans.purchase.query.dto.PurchaseRequestProductSimpleDto"
                    resultMap="purchaseRequestProductResultMap"/>
    </resultMap>

    <!-- 목록 조회 쿼리들 -->
    <select id="selectByStatus" resultMap="purchaseRequestSimpleResultMap">
        SELECT * FROM purchase_request
        WHERE status = #{status}
        ORDER BY created_at DESC
        <if test="limit != null and offset != null">
            LIMIT #{limit} OFFSET #{offset}
        </if>
    </select>

    <select id="selectByTitle" resultMap="purchaseRequestSimpleResultMap">
        SELECT * FROM purchase_request
        WHERE title LIKE CONCAT('%', #{title}, '%')
        ORDER BY created_at DESC
        <if test="limit != null and offset != null">
            LIMIT #{limit} OFFSET #{offset}
        </if>
    </select>

    <select id="selectByCode" resultMap="purchaseRequestSimpleResultMap">
        SELECT * FROM purchase_request
        WHERE code LIKE CONCAT('%', #{code}, '%')
        ORDER BY created_at DESC
        <if test="limit != null and offset != null">
            LIMIT #{limit} OFFSET #{offset}
        </if>
    </select>

    <!-- 상세 조회 -->
    <select id="selectDetailById" resultMap="purchaseRequestDetailResultMap">
        SELECT * FROM purchase_request
        WHERE id = #{id}
    </select>

    <select id="selectProductsByRequestId" resultMap="purchaseRequestProductResultMap">
        SELECT id AS product_id, no, quantity, remarks, product_id
        FROM purchase_request_product
        WHERE purchase_request_id = #{requestId}
        ORDER BY no ASC
    </select>

    <!-- count 쿼리들 -->
    <select id="countByStatus" resultType="int">
        SELECT COUNT(*) FROM purchase_request WHERE status = #{status}
    </select>

    <select id="countByTitle" resultType="int">
        SELECT COUNT(*) FROM purchase_request WHERE title LIKE CONCAT('%', #{title}, '%')
    </select>

    <select id="countByCode" resultType="int">
        SELECT COUNT(*) FROM purchase_request WHERE code LIKE CONCAT('%', #{code}, '%')
    </select>

</mapper>