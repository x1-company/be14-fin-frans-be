<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.x1.frans.purchaseorder.query.repository.PurchaseOrderQueryMapper">

    <resultMap id="purchaseOrderDraftListResultMap" type="com.x1.frans.purchaseorder.query.dto.PurchaseOrderDraftListDto">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="products" column="products"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="requestedDeliveryDate" column="requested_delivery_date"/>
    </resultMap>

    <select id="selectDraftOrders" resultMap="purchaseOrderDraftListResultMap">
        SELECT
            po.id
             , po.code
             , GROUP_CONCAT(p.name SEPARATOR ', ') AS products
             , po.total_amount
             , po.status
             , po.created_at
             , po.requested_delivery_date
        FROM purchase_order po
                 JOIN purchase_order_product pop ON po.id = pop.purchase_order_id
                 JOIN product p ON pop.product_id = p.id
        WHERE po.status = '임시저장'
        GROUP BY po.id, po.code, po.total_amount, po.status, po.created_at, po.requested_delivery_date
        ORDER BY po.created_at DESC
    </select>

</mapper>