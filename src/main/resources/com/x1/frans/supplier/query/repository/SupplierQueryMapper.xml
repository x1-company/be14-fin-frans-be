<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.x1.frans.supplier.query.repository.SupplierQueryMapper">
    <select id="getMyInfo" resultType="com.x1.frans.supplier.query.dto.MyInfoDTO">
        SELECT
            `id`
             , `code`
             , `name`
             , `phone`
             , `email`
        FROM `user`
        WHERE `id` = #{userId}
    </select>

</mapper>